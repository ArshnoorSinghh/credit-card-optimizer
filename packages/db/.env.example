# packages/db/.env — copy to .env and fill in, or run `vercel env pull`.
#
# Two URLs, because they are used for different things (see readme.md):
#   - serverless functions open many short-lived connections and must go through
#     the pooler;
#   - migrations need a direct session, because a transaction-mode pooler breaks
#     advisory locks and transactional DDL.

# Pooled (PgBouncer) — app queries at runtime.
DATABASE_URL=postgres://user:password@host:5432/dbname?pgbouncer=true

# Direct — `prisma migrate` only.
DIRECT_URL=postgres://user:password@host:5432/dbname
