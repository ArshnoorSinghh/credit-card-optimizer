# apps/web/.env.local — copy this file to .env.local and fill in.
#
# WHY THIS MATTERS: `next dev` hides the absence of these. Clerk runs a
# development-only "keyless mode" that auto-provisions a throwaway instance, so
# the whole site appears to work locally with no keys at all.
#
# In a production build it does not. ClerkProvider wraps the root layout, so a
# missing publishable key returns an error for EVERY route — including the static
# legal pages and /api/health, not just the auth screens. Verified with
# `pnpm --filter web build && pnpm --filter web start`: all routes fail.
#
# To reproduce production behaviour locally, use `next start`, never `next dev`.

# ---- Clerk (authentication) ----
# Free dev keys: https://dashboard.clerk.com → your app → API keys.
# You do NOT need the production deployment's keys to test locally — create your
# own Clerk application and use its development keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# ---- Database ----
# Needed by /api/optimize, which reads cards from Postgres (not from the engine's
# bundled dataset — /api/health uses that, which is why health can pass while
# optimize 500s). Vercel injects this in deployed environments; local dev does not.
# Use the POOLED connection string. See packages/db/.env.example for the pair.
DATABASE_URL=postgres://user:password@host:5432/dbname
